<% layout("/layouts/boilerplate") %>

<div class="container mt-5">

    <div class="row">

        <div class="col-md-8 offset-md-2">

            <div class="card shadow p-4">

                <h2>Edit Profile</h2>
                <form
                action="/profile?_method=PUT"
                method="POST"
                enctype="multipart/form-data"
            >

                    <div class="mb-3">

                        <label class="form-label">
                            Bio
                        </label>

                        <textarea
                            class="form-control"
                            name="bio"
                            rows="4"
                        ><%= user.bio %></textarea>

                    </div>

                    <div class="mb-3">

                        <label class="form-label">
                            Phone
                        </label>

                        <input
                            type="text"
                            class="form-control"
                            name="phone"
                            value="<%= user.phone %>"
                        >


                    </div>
                    <div class="mb-3">

                        <label class="form-label">
                            Profile Photo
                        </label>
                    
                        <input
                            type="file"
                            name="profileImage"
                            class="form-control"
                            accept="image/*"
                        >
                    
                    </div>

                    <button class="btn btn-success">
                        Save Changes
                    </button>

                </form>

            </div>

        </div>

    </div>

</div>