<% layout("/layouts/boilerplate") %>

<div class="container mt-4">

    <h2 class="mb-4">
        <i class="fa-solid fa-calendar-check"></i>
        My Bookings
    </h2>

    <% if(bookings.length === 0){ %>

        <div class="alert alert-info text-center">
            <h4>No Bookings Yet!</h4>
            <p>Book your first stay and it will appear here.</p>

            <a href="/listings" class="btn btn-danger">
                Explore Listings
            </a>
        </div>

    <% } else { %>

    <div class="row">

        <% bookings.forEach(booking => { %>

        <div class="col-lg-6 mb-4">

            <div class="card shadow booking-card h-100 <%= booking.status === 'Cancelled' ? 'cancelled-card' : '' %>">

                <img
                    src="<%= booking.listing.image.url %>"
                    class="card-img-top"
                    style="height:250px; object-fit:cover;"
                >

                <div class="card-body">

                    <h4 class="card-title">
                        <%= booking.listing.title %>
                    </h4>

                    <p class="text-muted mb-2">
                        <i class="fa-solid fa-location-dot text-danger"></i>
                        <%= booking.listing.location %>,
                        <%= booking.listing.country %>
                    </p>

                    <hr>

                    <p>
                        <strong>Check-In:</strong>
                        <%= booking.checkIn.toDateString() %>
                    </p>

                    <p>
                        <strong>Check-Out:</strong>
                        <%= booking.checkOut.toDateString() %>
                    </p>

                    <p>
                        <strong>Guests:</strong>
                        <%= booking.guests %>
                    </p>

                    <p>
                        <strong>Total Price:</strong>
                        ₹<%= booking.totalPrice.toLocaleString("en-IN") %>
                    </p>

                    <p>
                        <strong>Booked On:</strong>
                        <%= booking.createdAt.toDateString() %>
                    </p>

                    <% if(booking.status === "Confirmed"){ %>

                        <span class="badge bg-success fs-6">
                            ✅ Confirmed
                        </span>

                    <% } else { %>

                        <span class="badge bg-danger fs-6">
                            ❌ Cancelled
                        </span>

                    <% } %>

                    <div class="mt-3">

                        <a
                            href="/listings/<%= booking.listing._id %>"
                            class="btn btn-outline-primary"
                        >
                            <i class="fa-solid fa-eye"></i>
                            View Listing
                        </a>

                        <% if(booking.status === "Confirmed"){ %>

                        <form
                            action="/bookings/<%= booking._id %>?_method=DELETE"
                            method="POST"
                            class="d-inline"
                        >

                            <button
                                class="btn btn-danger"
                                onclick="return confirm('Are you sure you want to cancel this booking?')"
                            >
                                <i class="fa-solid fa-ban"></i>
                                Cancel Booking
                            </button>

                        </form>

                        <% } %>

                    </div>

                </div>

            </div>

        </div>

        <% }) %>

    </div>

    <% } %>

</div>