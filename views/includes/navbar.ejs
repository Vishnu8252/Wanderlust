<nav class="navbar navbar-expand-lg bg-white border-bottom sticky-top">

    <div class="container">

        <!-- Logo -->
        <a class="navbar-brand d-flex align-items-center" href="/listings">
            <i class="fa-regular fa-compass fs-2 text-danger"></i>
        </a>

        <!-- Mobile Toggle -->
        <button
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#navbarNav"
        >
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">

            <!-- Left -->
            <div class="navbar-nav">

                <a class="nav-link fw-medium" href="/listings">
                    Explore
                </a>

            </div>

            <!-- Search -->
            <form
                class="d-flex search-bar mx-auto my-2 my-lg-0"
                action="/listings/search"
                method="GET"
            >

                <input
                    class="form-control search-input"
                    type="search"
                    name="q"
                    value="<%= typeof search !== 'undefined' ? search : '' %>"
                    placeholder="Search destinations"
                    autocomplete="off"
                >

                <button
                    class="btn search-btn ms-2"
                    type="submit"
                >
                    <i class="fa-solid fa-magnifying-glass"></i>
                </button>

            </form>

            <!-- Right -->
            <div class="navbar-nav ms-auto align-items-center">

                <% if (!currUser) { %>

                    <a class="nav-link fw-medium" href="/listings/new">
                        Airbnb Your Home
                    </a>

                    <a class="nav-link fw-bold" href="/signup">
                        Sign Up
                    </a>

                    <a class="nav-link fw-bold" href="/login">
                        Log In
                    </a>

                <% } else { %>

                    <a class="nav-link fw-medium" href="/listings/new">
                        Airbnb Your Home
                    </a>

                    <a class="nav-link" href="/wishlist">
                        ❤️ Wishlist
                    </a>

                    <a class="nav-link" href="/bookings/my">
                        📅 My Bookings
                    </a>

                    <a
                        class="nav-link p-0 mx-2"
                        href="/profile"
                        title="My Profile"
                    >

                        <% if (currUser.profileImage && currUser.profileImage.url) { %>

                            <img
                                src="<%= currUser.profileImage.url %>"
                                alt="Profile"
                                class="rounded-circle border"
                                style="width:38px;height:38px;object-fit:cover;"
                            >

                        <% } else { %>

                            <img
                                src="/images/default-profile.png"
                                alt="Profile"
                                class="rounded-circle border"
                                style="width:38px;height:38px;object-fit:cover;"
                            >

                        <% } %>

                    </a>

                    <% if (currUser.isAdmin) { %>

                        <a
                            class="nav-link text-primary fw-semibold"
                            href="/admin"
                        >
                            👑 Admin
                        </a>

                    <% } %>

                    <a
                        class="nav-link text-danger fw-semibold"
                        href="/logout"
                    >
                        Logout
                    </a>

                <% } %>

            </div>

        </div>

    </div>

</nav>