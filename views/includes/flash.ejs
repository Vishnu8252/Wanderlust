<% if (success && success.length) { %>

    <div class="row justify-content-center mt-3">
    
        <div
            class="col-lg-6 col-md-8 col-11 alert alert-success alert-dismissible fade show shadow-sm"
            role="alert"
        >
    
            <%= success %>
    
            <button
                type="button"
                class="btn-close"
                data-bs-dismiss="alert"
                aria-label="Close"
            ></button>
    
        </div>
    
    </div>
    
    <% } %>
    
    
    <% if (error && error.length) { %>
    
    <div class="row justify-content-center mt-3">
    
        <div
            class="col-lg-6 col-md-8 col-11 alert alert-danger alert-dismissible fade show shadow-sm"
            role="alert"
        >
    
            <%= error %>
    
            <button
                type="button"
                class="btn-close"
                data-bs-dismiss="alert"
                aria-label="Close"
            ></button>
    
        </div>
    
    </div>
    
    <% } %>