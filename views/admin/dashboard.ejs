<% layout("/layouts/admin") %>

<div class="container my-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2>
            <i class="fa-solid fa-plane-departure"></i>
            Dashboard
        </h2>
        <span class="badge bg-dark fs-6">
            Welcome Admin
        </span>

    </div>

    <!-- Statistics -->

    <div class="row g-4">

        <div class="col-xl-3 col-md-6">

            <div class="card text-bg-primary shadow border-0 h-100">

                <div class="card-body text-center">

                    <i class="fa-solid fa-users fa-2x mb-3"></i>

                    <h5>Total Users</h5>

                    <h2 class="fw-bold">

                        <%= totalUsers %>

                    </h2>

                </div>

            </div>

        </div>

        <div class="col-xl-3 col-md-6">

            <div class="card text-bg-success shadow border-0 h-100">

                <div class="card-body text-center">

                    <i class="fa-solid fa-house fa-2x mb-3"></i>

                    <h5>Total Listings</h5>

                    <h2 class="fw-bold">

                        <%= totalListings %>

                    </h2>

                </div>

            </div>

        </div>

        <div class="col-xl-3 col-md-6">

            <div class="card text-bg-warning shadow border-0 h-100">

                <div class="card-body text-center">

                    <i class="fa-solid fa-star fa-2x mb-3"></i>

                    <h5>Total Reviews</h5>

                    <h2 class="fw-bold">

                        <%= totalReviews %>

                    </h2>

                </div>

            </div>

        </div>

        <div class="col-xl-3 col-md-6">

            <div class="card text-bg-danger shadow border-0 h-100">

                <div class="card-body text-center">

                    <i class="fa-solid fa-calendar-check fa-2x mb-3"></i>

                    <h5>Total Bookings</h5>

                    <h2 class="fw-bold">

                        <%= totalBookings || 0 %>

                    </h2>

                </div>

            </div>

        </div>

    </div>

    <!-- Quick Actions -->

    <div class="card shadow border-0 mt-5">

        <div class="card-body">

            <h4 class="mb-4">

                Quick Actions

            </h4>

            <div class="row g-3">

                <div class="col-md-4">

                    <a
                        href="/admin/users"
                        class="btn btn-outline-primary w-100"
                    >
                        <i class="fa-solid fa-users"></i>
                        Manage Users
                    </a>

                </div>

                <div class="col-md-4">

                    <a
                        href="/admin/listings"
                        class="btn btn-outline-success w-100"
                    >
                        <i class="fa-solid fa-house"></i>
                        Manage Listings
                    </a>

                </div>

                <div class="col-md-4">

                    <a
                        href="/admin/reviews"
                        class="btn btn-outline-warning w-100"
                    >
                        <i class="fa-solid fa-star"></i>
                        Manage Reviews
                    </a>

                </div>

                <div class="col-md-4">

                    <a
                        href="/admin/bookings"
                        class="btn btn-outline-danger w-100"
                    >
                        <i class="fa-solid fa-calendar-check"></i>
                        Manage Bookings
                    </a>

                </div>

                <div class="col-md-4">

                    <a
                        href="/admin/payments"
                        class="btn btn-outline-dark w-100"
                    >
                        <i class="fa-solid fa-credit-card"></i>
                        Payments
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>