<% layout("/layouts/admin") %>

<div class="container my-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="fw-bold">
            ⭐ Review Management
        </h2>

        <span class="badge bg-dark fs-6">
            Total Reviews:
            <%= listings.reduce((total, listing) => total + listing.reviews.length, 0) %>
        </span>

    </div>

    <%
        const totalReviews = listings.reduce(
            (total, listing) => total + listing.reviews.length,
            0
        );
    %>

    <% if(totalReviews === 0){ %>

        <div class="alert alert-info text-center">

            No reviews found.

        </div>

    <% } else { %>

    <div class="table-responsive">

        <table class="table table-hover align-middle">

            <thead class="table-dark">

                <tr>

                    <th>#</th>
                    <th>Listing</th>
                    <th>User</th>
                    <th>Rating</th>
                    <th>Comment</th>
                    <th class="text-center">
                        Action
                    </th>

                </tr>

            </thead>

            <tbody>

                <%
                    let count = 1;

                    listings.forEach(listing => {

                        listing.reviews.forEach(review => {
                %>

                <tr>

                    <td>

                        <%= count++ %>

                    </td>

                    <td class="fw-semibold">

                        <%= listing.title %>

                    </td>

                    <td>

                        <%= review.author?.username || "Unknown User" %>

                    </td>

                    <td>

                        <span class="badge bg-warning text-dark">

                            ⭐ <%= review.rating %>/5

                        </span>

                    </td>

                    <td style="max-width:300px;">

                        <%= review.comment %>

                    </td>

                    <td class="text-center">

                        <form
                            action="/admin/reviews/<%= review._id %>?_method=DELETE"
                            method="POST"
                            onsubmit="return confirm('Delete this review permanently?');"
                        >

                            <button
                                class="btn btn-danger btn-sm"
                            >

                                <i class="fa-solid fa-trash"></i>

                                Delete

                            </button>

                        </form>

                    </td>

                </tr>

                <%
                        });

                    });
                %>

            </tbody>

        </table>

    </div>

    <% } %>

</div>