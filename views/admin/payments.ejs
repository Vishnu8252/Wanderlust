<% layout("/layouts/admin") %>

<div class="container my-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="fw-bold">
            💳 Payment Management
        </h2>

        <span class="badge bg-dark fs-6">
            Total Payments: <%= bookings.length %>
        </span>

    </div>

    <% if (bookings.length === 0) { %>

        <div class="alert alert-info text-center">
            No payment records found.
        </div>

    <% } else { %>

    <div class="table-responsive">

        <table class="table table-hover align-middle">

            <thead class="table-dark">

                <tr>
                    <th>#</th>
                    <th>User</th>
                    <th>Listing</th>
                    <th>Amount</th>
                    <th>Payment ID</th>
                    <th>Order ID</th>
                    <th>Payment Status</th>
                    <th>Refund Status</th>
                    <th>Date</th>
                </tr>

            </thead>

            <tbody>

                <% bookings.forEach((booking,index)=>{ %>

                <tr>

                    <td><%= index + 1 %></td>

                    <td><%= booking.user?.username || "Deleted User" %></td>

                    <td><%= booking.listing?.title || "Deleted Listing" %></td>

                    <td class="fw-bold">
                        ₹ <%= (booking.totalPrice || 0).toLocaleString("en-IN") %>
                    </td>

                    <td>
                        <small><%= booking.paymentId || "-" %></small>
                    </td>

                    <td>
                        <small><%= booking.orderId || "-" %></small>
                    </td>

                    <td>
                        <% if (booking.paymentStatus === "Paid") { %>
                            <span class="badge bg-success">Paid</span>
                        <% } else { %>
                            <span class="badge bg-warning text-dark">Pending</span>
                        <% } %>
                    </td>

                    <td>
                        <% if (booking.refundStatus === "Refunded") { %>
                            <span class="badge bg-info text-dark">Refunded</span>
                        <% } else { %>
                            <span class="badge bg-secondary">Not Refunded</span>
                        <% } %>
                    </td>

                    <td>
                        <%= booking.createdAt.toLocaleDateString("en-IN") %>
                    </td>

                </tr>

                <% }) %>

            </tbody>

        </table>

    </div>

    <% } %>

</div>