<% layout("/layouts/boilerplate") %>

<div class="container my-4">

    <div class="row justify-content-center">

        <div class="col-lg-10">

            <h2 class="fw-bold mb-3">
                <%= listing.title %>
            </h2>

            <div class="card shadow-sm border-0 show-card">

                <img
                    src="<%= listing.image.url %>"
                    alt="<%= listing.title %>"
                    class="card-img-top show-img"
                    loading="lazy"
                >

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center flex-wrap mb-3">

                        <div>

                            <h5 class="mb-1">
                                Hosted by
                                <strong>
                                    <%= listing.owner.username %>
                                </strong>
                            </h5>

                            <small class="text-muted">
                                <%= listing.location %>,
                                <%= listing.country %>
                            </small>

                        </div>

                        <% if(currUser){ %>

                            <form
                                action="/wishlist/<%= listing._id %>"
                                method="POST"
                                class="mt-2 mt-md-0"
                            >

                                <% if(isWishlisted){ %>

                                    <button
                                        class="btn btn-danger"
                                        type="submit"
                                    >
                                        ❤️ Wishlisted
                                    </button>

                                <% } else { %>

                                    <button
                                        class="btn btn-outline-danger"
                                        type="submit"
                                    >
                                        🤍 Wishlist
                                    </button>

                                <% } %>

                            </form>

                        <% } %>

                    </div>

                    <hr>

                    <p class="card-text">

                        <%= listing.description %>

                    </p>

                    <h4 class="fw-bold mt-4">

                        ₹
                        <%= listing.price.toLocaleString("en-IN") %>

                        <small class="text-muted fs-6">
                            / night
                        </small>

                    </h4>

                    <% if(
                        currUser &&
                        listing.owner._id.equals(currUser._id)
                    ){ %>

                        <hr>

                        <div class="d-flex gap-2">

                            <a
                                href="/listings/<%= listing._id %>/edit"
                                class="btn btn-dark"
                            >
                                Edit Listing
                            </a>

                            <form
                                action="/listings/<%= listing._id %>?_method=DELETE"
                                method="POST"
                                onsubmit="return confirm('Are you sure you want to delete this listing?');"
                            >

                                <button
                                    class="btn btn-outline-danger"
                                >
                                    Delete Listing
                                </button>

                            </form>

                        </div>

                    <% } %>

                </div>

            </div>

        </div>

    </div>

</div>
<% if (currUser) { %>

<hr class="my-4">

<div class="booking-section">

    <h3 class="mb-4">
        Book This Stay
    </h3>

    <script>
        const bookedDates = <%- JSON.stringify(bookings || []) %>;
    </script>

    <form
        id="booking-form"
        action="/listings/<%= listing._id %>/bookings"
        method="POST"
        class="needs-validation"
        novalidate
    >

        <div class="row">

            <div class="col-md-6 mb-3">

                <label
                    for="checkIn"
                    class="form-label"
                >
                    Check-In
                </label>

                <input
                    type="text"
                    id="checkIn"
                    name="checkIn"
                    class="form-control"
                    placeholder="Select check-in date"
                    autocomplete="off"
                    required
                >

                <div class="invalid-feedback">
                    Please select your check-in date.
                </div>

            </div>

            <div class="col-md-6 mb-3">

                <label
                    for="checkOut"
                    class="form-label"
                >
                    Check-Out
                </label>

                <input
                    type="text"
                    id="checkOut"
                    name="checkOut"
                    class="form-control"
                    placeholder="Select check-out date"
                    autocomplete="off"
                    required
                >

                <div class="invalid-feedback">
                    Please select your check-out date.
                </div>

            </div>

        </div>

        <div class="mb-3">

            <label
                for="guests"
                class="form-label"
            >
                Guests
            </label>

            <input
                type="number"
                id="guests"
                name="guests"
                class="form-control"
                min="1"
                max="10"
                value="1"
                required
            >

            <div class="invalid-feedback">
                Number of guests must be between 1 and 10.
            </div>

        </div>

        <input
            type="hidden"
            id="listingId"
            value="<%= listing._id %>"
        >

        <input
            type="hidden"
            id="pricePerNight"
            value="<%= listing.price %>"
        >

        <!-- Booking Summary -->

        <div
            class="card bg-light border-0 mb-4"
            id="bookingSummary"
        >

            <div class="card-body">

                <h5 class="card-title mb-3">
                    Booking Summary
                </h5>

                <div
                    class="d-flex justify-content-between"
                >
                    <span>
                        Price / Night
                    </span>

                    <span>

                        ₹
                        <%= listing.price.toLocaleString("en-IN") %>

                    </span>

                </div>

                <div
                    class="d-flex justify-content-between mt-2"
                >

                    <span>
                        Nights
                    </span>

                    <span id="totalNights">
                        0
                    </span>

                </div>

                <hr>

                <div
                    class="d-flex justify-content-between fw-bold"
                >

                    <span>
                        Total
                    </span>

                    <span id="totalPrice">
                        ₹0
                    </span>

                </div>

            </div>

        </div>

        <button
            type="button"
            id="pay-btn"
            class="btn btn-danger btn-lg w-100"
        >

            <i class="fa-solid fa-credit-card"></i>

            Pay & Book

        </button>

    </form>

</div>

<% } %>
<!-- ================= REVIEW SECTION ================= -->

<% if (currUser) { %>

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <hr>

            <h3 class="mb-4">
                Leave a Review
            </h3>

            <form
                method="POST"
                action="/listings/<%= listing._id %>/reviews"
                class="needs-validation"
                novalidate
            >

                <fieldset class="starability-slot mb-4">

                    <legend class="mb-3">
                        Rating
                    </legend>

                    <input
                        type="radio"
                        id="rate1"
                        name="review[rating]"
                        value="1"
                        checked
                    >
                    <label for="rate1" title="Poor">
                        1 Star
                    </label>

                    <input
                        type="radio"
                        id="rate2"
                        name="review[rating]"
                        value="2"
                    >
                    <label for="rate2" title="Fair">
                        2 Stars
                    </label>

                    <input
                        type="radio"
                        id="rate3"
                        name="review[rating]"
                        value="3"
                    >
                    <label for="rate3" title="Average">
                        3 Stars
                    </label>

                    <input
                        type="radio"
                        id="rate4"
                        name="review[rating]"
                        value="4"
                    >
                    <label for="rate4" title="Very Good">
                        4 Stars
                    </label>

                    <input
                        type="radio"
                        id="rate5"
                        name="review[rating]"
                        value="5"
                    >
                    <label for="rate5" title="Amazing">
                        5 Stars
                    </label>

                    <span class="starability-focus-ring"></span>

                </fieldset>

                <div class="mb-3">

                    <label
                        for="comment"
                        class="form-label"
                    >
                        Your Review
                    </label>

                    <textarea
                        id="comment"
                        name="review[comment]"
                        rows="5"
                        class="form-control"
                        placeholder="Share your experience..."
                        required
                    ></textarea>

                    <div class="invalid-feedback">
                        Please enter your review.
                    </div>

                </div>

                <button
                    class="btn btn-dark"
                    type="submit"
                >
                    Submit Review
                </button>

            </form>

            <hr class="mt-5">

        </div>

    </div>

</div>

<% } %>


<!-- ================= ALL REVIEWS ================= -->

<div class="container mb-5">

    <div class="row justify-content-center">

        <div class="col-lg-10">

            <h3 class="mb-4">

                Reviews

                <span class="text-muted">

                    (<%= listing.reviews.length %>)

                </span>

            </h3>

            <% if (listing.reviews.length === 0) { %>

                <div class="alert alert-light border">

                    <p class="mb-0 text-muted">

                        No reviews yet.

                        Be the first to review this stay!

                    </p>

                </div>

            <% } else { %>

                <div class="row">

                    <% for (let review of listing.reviews) { %>

                    <div class="col-md-6 mb-4">

                        <div class="card shadow-sm review-card h-100">

                            <div class="card-body">

                                <div class="d-flex justify-content-between align-items-center mb-3">

                                    <h5 class="mb-0">

                                        @<%= review.author ? review.author.username : "Deleted User" %>

                                    </h5>

                                    <span
                                        class="starability-result"
                                        data-rating="<%= review.rating %>"
                                    >
                                        Rated:
                                        <%= review.rating %>
                                    </span>

                                </div>

                                <p class="card-text">

                                    <%= review.comment %>

                                </p>

                                <% if (
                                    currUser &&
                                    review.author &&
                                    review.author._id.equals(currUser._id)
                                ) { %>

                                    <form
                                        method="POST"
                                        action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                                        onsubmit="return confirm('Delete this review?');"
                                    >

                                        <button
                                            class="btn btn-sm btn-outline-danger"
                                        >
                                            Delete Review
                                        </button>

                                    </form>

                                <% } %>

                            </div>

                        </div>

                    </div>

                    <% } %>

                </div>

            <% } %>

        </div>

    </div>

</div>
