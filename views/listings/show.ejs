<!-- ================= BOOTSTRAP VALIDATION ================= -->

<script>

(() => {

    "use strict";

    const forms =
        document.querySelectorAll(".needs-validation");

    Array.from(forms).forEach((form) => {

        form.addEventListener("submit", (event) => {

            if (!form.checkValidity()) {

                event.preventDefault();
                event.stopPropagation();

            }

            form.classList.add("was-validated");

        });

    });

})();

</script>

<!-- ================= TAX DISPLAY ================= -->

<script>

const taxInfo =
document.querySelector(".tax-info");

if (taxInfo) {

    taxInfo.style.display = "none";

}

</script>

<!-- ================= BOOKING SUMMARY ================= -->

<script>

const checkIn =
document.querySelector("#checkIn");

const checkOut =
document.querySelector("#checkOut");

const nightsElement =
document.querySelector("#totalNights");

const totalPriceElement =
document.querySelector("#totalPrice");

const pricePerNight =
Number(
document.querySelector("#pricePerNight")?.value || 0
);

function updateBookingSummary() {

    if (!checkIn || !checkOut) return;

    if (!checkIn.value || !checkOut.value) {

        nightsElement.textContent = "0";
        totalPriceElement.textContent = "₹0";

        return;

    }

    const start =
    new Date(checkIn.value);

    const end =
    new Date(checkOut.value);

    const difference =
    end - start;

    const nights =
    Math.ceil(
        difference / (1000 * 60 * 60 * 24)
    );

    if (nights > 0) {

        nightsElement.textContent =
        nights;

        totalPriceElement.textContent =
        "₹" +
        (nights * pricePerNight)
        .toLocaleString("en-IN");

    } else {

        nightsElement.textContent = "0";

        totalPriceElement.textContent = "₹0";

    }

}

if (checkIn && checkOut) {

    checkIn.addEventListener(
        "change",
        updateBookingSummary
    );

    checkOut.addEventListener(
        "change",
        updateBookingSummary
    );

}

</script>

