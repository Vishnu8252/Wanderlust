<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
    <div class="col-8 offset-2">

        <h2 class="fw-bold mb-4">
            Create New Listing
        </h2>

        <form
        method="POST"
        action="/listings"
        enctype="multipart/form-data"
        class="needs-validation"
        novalidate
        autocomplete="off"
    >

            <div class="mb-3">
                <label for="title" class="form-label">Title</label>
                <input
                    type="text"
                    name="listing[title]"
                    class="form-control"
                    placeholder="Enter title"
                    required
                >
                <div class="invalid-feedback">
                    Please enter a title.
                </div>
            </div>

            <div class="mb-3">
                <label for="description" class="form-label">Description</label>

                <textarea
                    name="listing[description]"
                    class="form-control"
                    rows="4"
                    required
                ></textarea>

                <div class="invalid-feedback">
                    Please enter a description.
                </div>
            </div>

            <div class="mb-3">
                <label for="image" class="form-label">
                    Upload Image
                </label>

                <input
                    type="file"
                    name="listing[image]"
                    class="form-control"
                    required
                >

                <div class="invalid-feedback">
                    Please upload an image.
                </div>
            </div>

            <div class="row">

                <div class="col-md-4 mb-3">
                    <label for="price" class="form-label">Price</label>

                    <input
                        type="number"
                        name="listing[price]"
                        class="form-control"
                        placeholder="Enter price"
                        min="0"
                        required
                    >

                    <div class="invalid-feedback">
                        Please enter a valid price.
                    </div>
                </div>

                <div class="col-md-8 mb-3">
                    <label for="location" class="form-label">Location</label>

                    <input
                        type="text"
                        name="listing[location]"
                        class="form-control"
                        placeholder="Enter location"
                        required
                    >

                    <div class="invalid-feedback">
                        Please enter a location.
                    </div>
                </div>

            </div>

            <div class="mb-3">
                <label for="country" class="form-label">Country</label>

                <input
                    type="text"
                    name="listing[country]"
                    class="form-control"
                    placeholder="Enter country"
                    required
                >

                <div class="invalid-feedback">
                    Please enter a country.
                </div>
            </div>
            <div class="mb-3">
                <label for="category" class="form-label">Category</label>
            
                <select name="listing[category]" class="form-select" required>
                    <option value="trending">🔥 Trending</option>
                    <option value="rooms">🛏️ Rooms</option>
                    <option value="iconic-cities">🏙️ Iconic Cities</option>
                    <option value="mountains">⛰️ Mountains</option>
                    <option value="beachfront">🏖️ Beachfront</option>
                    <option value="camping">🏕️ Camping</option>
                    <option value="castles">🏰 Castles</option>
                    <option value="amazing-pools">🏊 Amazing Pools</option>
                    <option value="lakefront">🌊 Lakefront</option>
                    <option value="cabins">🏡 Cabins</option>
                    <option value="tropical">🌴 Tropical</option>
                    <option value="arctic">❄️ Arctic</option>
                    <option value="farms">🚜 Farms</option>
                    <option value="luxe">💎 Luxe</option>
                    <option value="pet-friendly">🐶 Pet Friendly</option>
                </select>
            </div>

            <button class="btn btn-dark">
                Add Listing
            </button>

        </form>

    </div>
</div>