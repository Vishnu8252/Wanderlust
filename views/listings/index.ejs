<% layout("/layouts/boilerplate") %>

<div class="filters-wrapper">
    <button class="scroll-btn left" id="scrollLeft">
        <i class="fa-solid fa-chevron-left"></i>
    </button>
    <div id="filters">

        <a href="/listings" class="filter <%= selectedCategory === "trending" ? "active" : "" %>">
            <i class="fa-solid fa-fire"></i>
            <p>Trending</p>
        </a>

        <a href="/listings/filter/rooms" class="filter <%= selectedCategory === "rooms" ? "active" : "" %>">
            <i class="fa-solid fa-bed"></i>
            <p>Rooms</p>
        </a>

        <a href="/listings/filter/iconic-cities" class="filter <%= selectedCategory === "iconic-cities" ? "active" : "" %>">
            <i class="fa-solid fa-city"></i>
            <p>Iconic Cities</p>
        </a>

        <a href="/listings/filter/mountains" class="filter <%= selectedCategory === "mountains" ? "active" : "" %>">
            <i class="fa-solid fa-mountain"></i>
            <p>Mountains</p>
        </a>

        <a href="/listings/filter/beachfront" class="filter <%= selectedCategory === "beachfront" ? "active" : "" %>">
            <i class="fa-solid fa-umbrella-beach"></i>
            <p>Beachfront</p>
        </a>

        <a href="/listings/filter/camping" class="filter <%= selectedCategory === "camping" ? "active" : "" %>">
            <i class="fa-solid fa-campground"></i>
            <p>Camping</p>
        </a>

        <a href="/listings/filter/castles" class="filter <%= selectedCategory === "castles" ? "active" : "" %>">
            <i class="fa-solid fa-chess-rook"></i>
            <p>Castles</p>
        </a>

        <a href="/listings/filter/amazing-pools" class="filter <%= selectedCategory === "amazing-pools" ? "active" : "" %>">
            <i class="fa-solid fa-person-swimming"></i>
            <p>Amazing Pools</p>
        </a>

        <a href="/listings/filter/lakefront" class="filter <%= selectedCategory === "lakefront" ? "active" : "" %>">
            <i class="fa-solid fa-water"></i>
            <p>Lakefront</p>
        </a>

        <a href="/listings/filter/cabins" class="filter <%= selectedCategory === "cabins" ? "active" : "" %>">
            <i class="fa-solid fa-house"></i>
            <p>Cabins</p>
        </a>

        <a href="/listings/filter/tropical" class="filter <%= selectedCategory === "tropical" ? "active" : "" %>">
            <i class="fa-solid fa-tree"></i>
            <p>Tropical</p>
        </a>

        <a href="/listings/filter/arctic" class="filter <%= selectedCategory === "arctic" ? "active" : "" %>">
            <i class="fa-regular fa-snowflake"></i>
            <p>Arctic</p>
        </a>

        <a href="/listings/filter/farms" class="filter <%= selectedCategory === "farms" ? "active" : "" %>">
            <i class="fa-solid fa-tractor"></i>
            <p>Farms</p>
        </a>

        <a href="/listings/filter/luxe" class="filter <%= selectedCategory === "luxe" ? "active" : "" %>">
            <i class="fa-solid fa-gem"></i>
            <p>Luxe</p>
        </a>

        <a href="/listings/filter/pet-friendly" class="filter <%= selectedCategory === "pet-friendly" ? "active" : "" %>">
            <i class="fa-solid fa-paw"></i>
            <p>Pet Friendly</p>
        </a>

    </div>
    <button class="scroll-btn right" id="scrollRight">
        <i class="fa-solid fa-chevron-right"></i>
    </button>

    <div class="tax-toggle">

        <div class="form-check form-switch">

            <input
                class="form-check-input"
                type="checkbox"
                id="taxSwitch"
            >

            <label
                class="form-check-label"
                for="taxSwitch"
            >
                Display Total Before Taxes
            </label>

        </div>

    </div>

</div>


<% if (allListings.length === 0) { %>

<div class="text-center my-5">

    <h3>No Listings Found</h3>

    <p class="text-muted">
        Try another search or category.
    </p>

</div>

<% } else { %>

<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4">

<% for (let listing of allListings) { %>

<div class="col">

    <div class="position-relative">

        <% if (currUser) { %>

        <%
            const isWishlisted =
                currUser.wishlist &&
                currUser.wishlist.some(
                    item => item.toString() === listing._id.toString()
                );
        %>

        <form
            action="/wishlist/<%= listing._id %>"
            method="POST"
            class="wishlist-form"
        >

            <button
                class="wishlist-btn"
                type="submit"
            >
                <%= isWishlisted ? "❤️" : "🤍" %>
            </button>

        </form>

        <% } %>

        <a
            href="/listings/<%= listing._id %>"
            class="listing-link"
        >

            <div class="card listing-card h-100">

                <img
                    src="<%= listing.image.url %>"
                    class="card-img-top"
                    alt="<%= listing.title %>"
                    loading="lazy"
                >

                <div class="card-img-overlay"></div>

                <div class="card-body">

                    <h5 class="card-title">
                        <%= listing.title %>
                    </h5>

                    <p class="text-muted mb-1">

                        <%= listing.location %>,
                        <%= listing.country %>

                    </p>

                    <p class="card-text">

                        <strong>

                            ₹ <%= listing.price.toLocaleString("en-IN") %>

                        </strong>

                        / night

                        <span class="tax-info">

                            &nbsp;+18% GST

                        </span>

                    </p>

                </div>

            </div>

        </a>

    </div>

</div>

<% } %>

</div>

<% } %>


<script>

const taxSwitch = document.querySelector("#taxSwitch");
const taxInfo = document.querySelectorAll(".tax-info");

taxSwitch.addEventListener("change", () => {

    taxInfo.forEach((info) => {

        info.style.display =
            taxSwitch.checked
                ? "inline"
                : "none";

    });

});

</script>
<script>

    const filters = document.getElementById("filters");
    
    document.getElementById("scrollRight").onclick = () => {
        filters.scrollBy({
            left:350,
            behavior:"smooth"
        });
    };
    
    document.getElementById("scrollLeft").onclick = () => {
        filters.scrollBy({
            left:-350,
            behavior:"smooth"
        });
    };
    
    </script>